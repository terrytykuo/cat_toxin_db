# Admin-only config. Copy to admin/.env.local (gitignored).

# Shared secret required in the x-admin-secret header for every /api/* request.
# The Vite dev server injects this header automatically via proxy — the browser
# never sees it. Generate with: openssl rand -hex 32
ADMIN_SECRET=change-me

# Path to the Firebase Admin SDK service-account JSON file.
# Can be absolute, or relative to the admin/ directory.
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_ADMIN_KEY_PATH=/absolute/path/to/service-account.json
