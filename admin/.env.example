# Path to your Firebase Admin SDK service account JSON key file.
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_ADMIN_KEY_PATH=/absolute/path/to/your/service-account.json

# Shared secret used to authenticate requests between the admin frontend and server.
# Generate with: openssl rand -hex 32
ADMIN_SECRET=your_random_secret_here

# Vite env var for the admin frontend (same value as ADMIN_SECRET above).
VITE_ADMIN_SECRET=your_random_secret_here
